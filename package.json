{
  "name": "freeappstore-agent",
  "private": true,
  "repository": "https://github.com/freeappstore-online/agent",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check --diagnostic-level=error src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/workers-types": "^4.20250415.0",
    "@vitest/coverage-v8": "^4.1.6",
    "knip": "^6.14.0",
    "typescript": "^5.7",
    "vitest": "^4.1.5",
    "wrangler": "^4"
  }
}
